load("//bazel:api.bzl", "modular_py_library", "modular_py_test", "requirement")

package(default_visibility = [
    "//:__pkg__",
    "//max/tests:__subpackages__",
    "//oss/modular/max/tests:__subpackages__",
])

# Force-load the build-warmed eager-GC cache instead of cold-compiling the GC
# sweep on the timed test's critical path (MXF-533). GPU takes the CPU+accel
# warm, CPU the CPU warm; the default branch satisfies the pydeps lint aspect.
_GPU_WARM_DATA = select({
    "//:b200_gpu": ["//max/tests/integration/xarch_warm:compose"],
    "//:h100_gpu": ["//max/tests/integration/xarch_warm:compose"],
    "//:mi355_gpu": ["//max/tests/integration/xarch_warm:compose"],
    "//conditions:default": [],
})

_GPU_WARM_RLOCATION = select({
    "//:b200_gpu": {"XARCH_WARM_RLOCATION": "$(rlocationpath //max/tests/integration/xarch_warm:compose)"},
    "//:h100_gpu": {"XARCH_WARM_RLOCATION": "$(rlocationpath //max/tests/integration/xarch_warm:compose)"},
    "//:mi355_gpu": {"XARCH_WARM_RLOCATION": "$(rlocationpath //max/tests/integration/xarch_warm:compose)"},
    "//conditions:default": {},
})

modular_py_library(
    name = "test_helpers",
    testonly = True,
    srcs = ["_test_helpers.py"],
    imports = ["."],
    deps = [
        "//max/python/max/experimental",
        requirement("numpy"),
    ],
)

# Base class files shared between simulated and multi-GPU test targets.
modular_py_library(
    name = "test_base",
    testonly = True,
    srcs = glob(
        [
            "functional/_*.py",
            "module/_*.py",
        ],
        exclude = [
            "functional/__init__.py",
            "module/__init__.py",
        ],
    ) + [
        "functional/__init__.py",
        "module/__init__.py",
    ],
    imports = ["."],
    deps = [
        "//max/python/max:tensor",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/experimental",
        "//max/python/max/experimental/nn",
        "//max/python/max/graph",
        requirement("numpy"),
        requirement("pytest"),
    ],
)

# Package-scope warm-adoption conftest, shared via deps across both subdirs
# (pytest collects a package-root conftest for its subdir tests). Carries the
# runfiles dep for rlocation lookup.
modular_py_library(
    name = "conftest",
    testonly = True,
    srcs = ["conftest.py"],
    imports = ["."],
    deps = ["@rules_python//python/runfiles"],
)

# Simulated multi-device tests on CPU — runs on all CI (no GPU needed).
modular_py_test(
    name = "tests_simulated_cpu",
    size = "large",
    srcs = [
        "module/test_module_internals.py",
        "sharding/__init__.py",
        "test_tensor_sharding.py",
    ] + glob([
        "sharding/test_*.py",
        "functional/test_*_simulated_cpu.py",
        "module/test_*_simulated_cpu.py",
    ]),
    data = ["//max/tests/integration/xarch_warm:warm_cpu"],
    env = {
        # Batch-compile the GC matrix once at import, not lazily per dispatch.
        "MAX_EAGER_OP_PRECOMPILE": "1",
        # Adopt the build-warmed CPU GC cache, not cold-compile (MXF-533).
        "MODULAR_EAGER_WARM_ADOPT_ASSERTED": "1",
        "XARCH_WARM_RLOCATION": "$(rlocationpath //max/tests/integration/xarch_warm:warm_cpu)",
    },
    ignore_extra_deps = [
        # pytest collects conftest at runtime; it is not imported.
        ":conftest",
        # lazy import
        "//max/python/max/_interpreter_ops",
    ],
    imports = ["."],
    per_test_shard_count = {
        "module/test_compiled_simulated_cpu.py": 9,
        "module/test_dp_dynamic_simulated_cpu.py": 4,
    },
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        ":conftest",
        ":test_base",
        ":test_helpers",
        "//max/python/max:tensor",
        "//max/python/max/_interpreter_ops",
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/engine",
        "//max/python/max/experimental",
        "//max/python/max/experimental/nn",
        "//max/python/max/graph",
        requirement("numpy"),
    ],
)

# Pure-metadata sharding rule tests — no Tensor, no device, no graph.
modular_py_test(
    name = "tests_rules",
    size = "medium",
    srcs = glob(["rules/test_*.py"]) + [
        "rules/__init__.py",
        "rules/_fixtures.py",
    ],
    imports = ["."],
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        "//max/python/max/driver",
        "//max/python/max/dtype",
        "//max/python/max/experimental",
        "//max/python/max/graph",
    ],
)

# Simulated multi-device tests on a single GPU — validates that the
# simulated path works on GPU (important for testing GPU-only fused ops
# in a multi-device setting without requiring multiple physical GPUs).
modular_py_test(
    name = "tests_simulated_gpu",
    size = "large",
    srcs = glob([
        "functional/test_*_simulated_gpu.py",
        "module/test_*_simulated_gpu.py",
    ]),
    data = _GPU_WARM_DATA,
    env = {
        # Batch-compile the GC matrix once at import, not lazily per dispatch.
        "MAX_EAGER_OP_PRECOMPILE": "1",
        # Adopt the build-warmed GC cache, not cold-compile (MXF-533).
        "MODULAR_EAGER_WARM_ADOPT_ASSERTED": "1",
    } | _GPU_WARM_RLOCATION,
    exec_properties = {
        "test.resources:gpu-memory": "2",
    },
    gpu_constraints = ["//:has_gpu"],
    ignore_extra_deps = [
        # pytest collects conftest at runtime; it is not imported.
        ":conftest",
        # lazy import
        "//max/python/max/_interpreter_ops",
    ],
    imports = ["."],
    tags = ["gpu"],
    target_compatible_with = select({
        "//:asan": ["@platforms//:incompatible"],
        "@platforms//os:macos": ["@platforms//:incompatible"],
        "//conditions:default": [],
    }),
    deps = [
        ":conftest",
        ":test_base",
        ":test_helpers",
        "//max/python/max/_interpreter_ops",
        "//max/python/max/driver",
        "//max/python/max/experimental",
    ],
)

# Real multi-GPU tests — requires 4 GPUs.
# Split into separate targets so each file runs in its own process.
# Running all multi-GPU tests in a single process causes
# CUDA_ERROR_MISALIGNED_ADDRESS on H100 due to signal buffer
# accumulation across many EagerRealizationContext lifecycles.
[
    modular_py_test(
        name = src.replace("/", "/").removesuffix(".py"),
        size = "enormous",
        srcs = [
            src,
        ],
        data = _GPU_WARM_DATA,
        env = {
            # Batch-compile the GC matrix once at import, not lazily per dispatch.
            "MAX_EAGER_OP_PRECOMPILE": "1",
            # Adopt the build-warmed GC cache, not cold-compile (MXF-533).
            "MODULAR_EAGER_WARM_ADOPT_ASSERTED": "1",
        } | _GPU_WARM_RLOCATION,
        exec_properties = {
            "test.resources:gpu-memory": "4",
        },
        gpu_constraints = ["//:has_4_gpus"],
        ignore_extra_deps = [
            # pytest collects conftest at runtime; it is not imported.
            ":conftest",
            ":test_base",
            ":test_helpers",
            requirement("numpy"),
        ],
        imports = ["."],
        tags = ["gpu"],
        target_compatible_with = select({
            "//:asan": ["@platforms//:incompatible"],
            "@platforms//os:macos": ["@platforms//:incompatible"],
            "//conditions:default": [],
        }),
        deps = [
            ":conftest",
            ":test_base",
            ":test_helpers",
            "//max/python/max/driver",
            "//max/python/max/experimental",
            requirement("numpy"),
        ],
    )
    for src in glob(["functional/test_*_multi_gpu.py"])
]

[
    modular_py_test(
        name = src.replace("/", "/").removesuffix(".py"),
        size = "enormous",
        srcs = [
            src,
        ],
        data = _GPU_WARM_DATA,
        env = {
            # Batch-compile the GC matrix once at import, not lazily per dispatch.
            "MAX_EAGER_OP_PRECOMPILE": "1",
            # Adopt the build-warmed GC cache, not cold-compile (MXF-533).
            "MODULAR_EAGER_WARM_ADOPT_ASSERTED": "1",
        } | _GPU_WARM_RLOCATION,
        exec_properties = {
            "test.resources:gpu-memory": "4",
        },
        gpu_constraints = ["//:has_4_gpus"],
        ignore_extra_deps = [
            # pytest collects conftest at runtime; it is not imported.
            ":conftest",
            ":test_helpers",
            "//max/python/max/experimental",
            "//max/python/max/experimental/nn",
        ],
        imports = ["."],
        tags = ["gpu"],
        target_compatible_with = select({
            "//:asan": ["@platforms//:incompatible"],
            "@platforms//os:macos": ["@platforms//:incompatible"],
            "//conditions:default": [],
        }),
        deps = [
            ":conftest",
            ":test_base",
            ":test_helpers",
            "//max/python/max/driver",
            "//max/python/max/experimental",
            "//max/python/max/experimental/nn",
        ],
    )
    for src in glob(["module/test_*_multi_gpu.py"])
]
