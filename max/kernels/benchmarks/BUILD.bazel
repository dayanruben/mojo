_CPU_TESTS = glob(
    ["**/*.mojo"],
    exclude = [
        "**/*.yaml",
        "autotune/**",
        "demos/**",
        "gpu/**",
        "misc/**",
        "packages/**",
    ] + _RUN_BENCHMARKS,
)

[
    mojo_binary(
        name = src.split(".")[0],
        srcs = [src],
        enable_assertions = False,
        target_compatible_with = _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:comm",
            "//max:internal_utils",
            "//max:layout",
            "//max:nn",
            "@mojo//:std",
        ],
    )
    for src in _CPU_TESTS
]

[
    build_test(
        name = src + ".test",
        targets = [src.split(".")[0]],
    )
    for src in _CPU_TESTS
]

[
    mojo_test(
        name = src + ".test",
        size = "enormous",
        srcs = [src],
        args = ["-t"],
        enable_assertions = False,
        target_compatible_with = _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:comm",
            "//max:internal_utils",
            "//max:layout",
            "//max:nn",
            "@mojo//:std",
        ],
    )
    for src in _RUN_BENCHMARKS
]

[
    mojo_binary(
        name = src.split(".")[0],
        srcs = [src],
        data = select({
            "//:nvidia_gpu": ["@nvshmem_prebuilt//:host"],
            "//conditions:default": [],
        }),
        enable_assertions = False,
        env = select({
            "//:nvidia_gpu": {"MODULAR_SHMEM_LIB_DIR": "../+http_archive+nvshmem_prebuilt"},
            "//conditions:default": {},
        }),
        target_compatible_with = ["//:has_gpu"] + _EXTRA_CONSTRAINTS.get(src, []),
        deps = [
            "//max:comm",
            "//max:internal_utils",
            "//max:layout",
            "//max:nn",
            "//max:shmem",
            "//max:structured_kernels",
            "@mojo//:std",
        ],
    )
    for src in glob(
        ["gpu/**/*.mojo"],
        exclude = [
            "gpu/nn/bench_conv2d.mojo",
            "gpu/layout/bench_tile_io_copy.mojo",
            "gpu/nn/bench_conv3d.mojo",
            # Needs `-D fp32_scores/cadence` (gated FP32-scores path);
            # the generic glob can't pass them. Dedicated target below.
            "gpu/nn/bench_mla_prefill_v2.mojo",
        ],
    )
]

[
    build_test(
        name = src + ".test",
        tags = ["gpu"],
        targets = [src.split(".")[0]],
    )
    for src in glob(
        ["gpu/**/*.mojo"],
        exclude = [
            "gpu/nn/bench_conv2d.mojo",
            "gpu/layout/bench_tile_io_copy.mojo",
            "gpu/nn/bench_conv3d.mojo",
            # Needs `-D fp32_scores/cadence` (gated FP32-scores path);
            # the generic glob can't pass them. Dedicated target below.
            "gpu/nn/bench_mla_prefill_v2.mojo",
        ],
    )
]

# MlaPrefillV2 device-timed TFLOPS bench.
# Delegates numeric steps to the gated MlaPrefillV2Core FP32-scores / reference-cadence
# path, so it MUST compile with `-D fp32_scores=true -D cadence=true`
# (enables the gated path for THIS compile only; no kernel source is modified).
# gfx950 / MFMA 32x32x64 FP8. Excluded from the generic gpu/** glob above.
mojo_binary(
    name = "gpu/nn/bench_mla_prefill_v2",
    srcs = ["gpu/nn/bench_mla_prefill_v2.mojo"],
    copts = [
        "-D",
        "fp32_scores=true",
        "-D",
        "cadence=true",
    ],
    enable_assertions = False,
    target_compatible_with = ["//:mi355_gpu"],
    deps = [
        "//max:comm",
        "//max:internal_utils",
        "//max:layout",
        "//max:nn",
        "//max:shmem",
        "//max:structured_kernels",
        "@mojo//:std",
    ],
)

build_test(
    name = "gpu/nn/bench_mla_prefill_v2.test",
    tags = ["gpu"],
    targets = ["gpu/nn/bench_mla_prefill_v2"],
)

