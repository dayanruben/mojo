    # The bench's `impl` runtime arg picks which dispatcher to time
    # per shape.
    target_compatible_with = ["//:has_gpu"],
    deps = [
        "//max:internal_utils",
        "//max:layout",
        "//max:nn",
        "@mojo//:std",
    ],
)

