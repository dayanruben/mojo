load("//bazel:api.bzl", "modular_py_binary", "modular_py_library", "requirement")

package(default_visibility = ["//max:consumers"])

# HTTP route adapters that expose cascade pipelines as FastAPI apps.
modular_py_library(
    name = "serve",
    srcs = glob(
        ["*.py"],
        exclude = ["main.py"],
    ),
    deps = [
        requirement("fastapi"),
        requirement("pydantic"),
        requirement("sse-starlette"),
        requirement("uvicorn"),
        "//max/python/max/experimental/cascade/interfaces",
        "//max/python/max/pipelines/request",
        "//max/python/max/serve/schemas",
    ],
)

# Experimental cascade serving CLI entrypoint.
modular_py_binary(
    name = "main",
    srcs = ["main.py"],
    main = "main.py",
    tags = [
        "no-sandbox",
        "requires-network",
    ],
    # The all_pipelines dispatcher target pulls in every architecture (for the
    # registry's lazy runtime imports), so the server can serve any supported
    # model the user selects on the CLI.
    deps = [
        requirement("cyclopts"),
        "//max/python/max/experimental/cascade/deployment:context_config",
        "//max/python/max/experimental/cascade/pipelines:all_pipelines",
        "//max/python/max/experimental/cascade/serve",
        "//max/python/max/pipelines/lib",
    ],
)
